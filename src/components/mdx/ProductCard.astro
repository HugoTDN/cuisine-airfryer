---
import { withUtm } from '../../lib/utm';

interface Props {
  nom: string;
  marque: string;
  prix?: string;
  image?: string;
  note?: string;
  lienAmazon?: string;
  lienBoulanger?: string;
  campaign?: 'recette' | 'comparatif' | 'guide' | 'test' | 'homepage' | 'accessoire' | 'actualite';
}

const {
  nom,
  marque,
  prix,
  image,
  note,
  lienAmazon,
  lienBoulanger,
  campaign = 'comparatif',
} = Astro.props;
---

<div class="my-6 rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
  <div class="flex flex-col gap-4 sm:flex-row">
    {image && (
      <div class="flex-shrink-0">
        <img src={image} alt={nom} class="h-32 w-32 rounded object-contain" loading="lazy" width="128" height="128" />
      </div>
    )}
    <div class="flex-1">
      <p class="text-sm text-gray-500">{marque}</p>
      <h3 class="text-lg font-semibold">{nom}</h3>
      {note && <p class="text-sm text-amber-600 font-medium">{note}</p>}
      {prix && <p class="text-xl font-bold text-gray-900 mt-1">{prix}</p>}
      <slot />
      <div class="mt-3 flex flex-wrap gap-2">
        {lienAmazon && (
          <a
            href={withUtm(lienAmazon, campaign)}
            target="_blank"
            rel="sponsored nofollow noopener"
            class="inline-flex items-center rounded-md bg-amber-500 px-3 py-1.5 text-sm font-medium text-white hover:bg-amber-600"
          >
            Voir sur Amazon
          </a>
        )}
        {lienBoulanger && (
          <a
            href={withUtm(lienBoulanger, campaign)}
            target="_blank"
            rel="sponsored nofollow noopener"
            class="inline-flex items-center rounded-md bg-blue-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-blue-700"
          >
            Voir sur Boulanger
          </a>
        )}
      </div>
    </div>
  </div>
</div>
