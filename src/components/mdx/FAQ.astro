---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<section class="my-8">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <h2 class="text-2xl font-bold mb-4">Questions fréquentes</h2>
  <dl class="space-y-4">
    {items.map((item) => (
      <div class="border-b border-gray-200 pb-4">
        <dt class="font-semibold text-lg">{item.question}</dt>
        <dd class="mt-1 text-gray-700">{item.answer}</dd>
      </div>
    ))}
  </dl>
</section>
